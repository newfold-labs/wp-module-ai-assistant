{
    "name": "newfold-labs/wp-module-ai-assistant",
    "description": "Public-facing AI site assistant chatbot for WordPress",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Newfold Digital",
            "homepage": "https://newfold.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "NewfoldLabs\\WP\\Module\\AIAssistant\\": "includes"
        },
        "files": [
            "bootstrap.php"
        ]
    },
    "require": {
        "php": ">=7.3",
        "newfold-labs/wp-module-loader": "^1.0",
        "newfold-labs/wp-module-data": "^2.0",
        "newfold-labs/wp-module-features": "^1.0",
        "newfold-labs/wp-module-ai": "^1.3"
    },
    "repositories": {
        "newfold": {
            "type": "composer",
            "url": "https://newfold-labs.github.io/satis/",
            "only": [
                "newfold-labs/*"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
